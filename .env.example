# Copy to .env and fill in. bot.py loads this automatically via python-dotenv.

TELEGRAM_BOT_TOKEN=get_this_from_@BotFather_on_telegram
GROQ_API_KEY=get_this_free_from_console.groq.com

# Optional -- only needed when deploying with a persistent volume (Railway/Fly).
# Point this at a path INSIDE your mounted volume, e.g.:
#   Railway: DB_PATH=/app/data/kirana.db
#   Fly.io:  DB_PATH=/data/kirana.db
# Leave unset for local development -- defaults to ./kirana.db
# DB_PATH=
